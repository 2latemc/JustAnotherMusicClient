{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-close",
    "core:window:allow-is-fullscreen",
    "core:window:allow-is-maximized",
    "core:window:allow-unmaximize",
    "core:window:allow-set-fullscreen",
    "core:window:allow-set-decorations",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled",
    "opener:default",
    "updater:default",
    "process:allow-restart"
  ],
  "allowlist": {
    "shell": {
      "all": false,
      "open": true
    }
  },
  "remote": {
    "urls": ["https://**", "http://localhost/**", "http://127.0.0.1/**"]
  },
  "command": {
    "allow": [
      "greet",
      "quit_app",
      "frontend_log",
      "cache_get",
      "cache_set",
      "cache_stats",
      "cache_set_max_bytes",
      "cache_clear",
      "fetch_audio_bytes",
      "fetch_youtube_music_audio",
      "proxy_http_request",
      "update_windows_media_session",
      "save_youtube_credentials",
      "load_youtube_credentials",
      "delete_youtube_credentials",
      "load_youtube_music_cookie",
      "sign_in_youtube_music",
      "delete_youtube_music_cookie"
    ]
  }
}
